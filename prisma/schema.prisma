generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StockStatus {
  EN_STOCK
  STOCK_BAJO
  AGOTADO
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  EN_CAMINO
  ENTREGADO
  CANCELADO
}

enum PaymentMethod {
  TARJETA
  TRANSFERENCIA
  EFECTIVO
  WHATSAPP
}

enum PostType {
  COMBO
  INDIVIDUAL
  OFERTA
  BANNER
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  unit        String?
  stock       Int         @default(0)
  stockStatus StockStatus @default(EN_STOCK)
  images      String[]    @default([])
  specs       Json?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  brandId     String
  brand       Brand       @relation(fields: [brandId], references: [id])
  featured    Boolean     @default(false)
  orderItems  OrderItem[]
  comboItems  ComboItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  password  String
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  street     String
  city       String
  state      String
  postalCode String
  isDefault  Boolean @default(false)
  orders     Order[]
}

model Order {
  id             String        @id @default(cuid())
  number         Int           @unique @default(autoincrement())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  addressId      String?
  address        Address?      @relation(fields: [addressId], references: [id])
  items          OrderItem[]
  status         OrderStatus   @default(PENDIENTE)
  paymentMethod  PaymentMethod @default(TRANSFERENCIA)
  subtotal       Decimal       @db.Decimal(10, 2)
  shipping       Decimal       @default(0) @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  internalNotes  String?
  notifyWhatsapp Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
}

model Combo {
  id         String      @id @default(cuid())
  title      String
  subtitle   String?
  type       PostType    @default(COMBO)
  format     String      @default("CUADRADO")
  background String      @default("NEGRO")
  comboPrice Decimal?    @db.Decimal(10, 2)
  savings    Decimal?    @db.Decimal(10, 2)
  items      ComboItem[]
  createdAt  DateTime    @default(now())
}

model ComboItem {
  id        String  @id @default(cuid())
  comboId   String
  combo     Combo   @relation(fields: [comboId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model SiteSettings {
  id              String   @id @default("main")
  phone           String   @default("+52 (656) 123-4567")
  phone2          String   @default("")
  whatsapp        String   @default("526561234567")
  email           String   @default("contacto@diose.mx")
  address         String   @default("Av. de las Torres 1234, Col. Industrial, Cd. Juárez, Chih.")
  mapsUrl         String   @default("")
  heroSlides      Json     @default("[]")
  heroEyebrow        String   @default("Ciudad Juárez · 8 años de experiencia")
  heroTitle          String   @default("CONSTRUYE\nLO QUE\nIMAGINAS")
  heroTitleHighlight String   @default("LO QUE")
  heroTitleHighlightColor String @default("#1d5fb8")
  heroSubtitle       String   @default("Materiales de construcción, herramientas profesionales y suministros para cada obra en Ciudad Juárez.")
  heroCta1Label   String   @default("Ver Catálogo")
  heroCta1Link    String   @default("/catalogo")
  heroCta2Label   String   @default("Quiénes somos")
  heroCta2Link    String   @default("/nosotros")
  partnerLogoUrl  String   @default("")
  partnerName     String   @default("")
  updatedAt       DateTime @updatedAt
}

model PromoImage {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String?
  subtitle  String?
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
